{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "designbees-homepage-grader-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-03-26",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "browser": {
    "binding": "BROWSER"
